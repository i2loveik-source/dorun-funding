# Railway 환경변수 설정 가이드
# Railway 대시보드 → Variables 탭에서 아래 값들을 설정하세요.
# ⚠️ 실제 민감한 값은 .env에 넣지 말고 Railway Variables에만 입력하세요.

# ─── 필수 ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Neon DB (pooler 방식, Railway에서도 동일)
DATABASE_URL=postgresql://neondb_owner:npg_AGgSDQ3XLfH0@ep-lingering-waterfall-a1epxk84-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# 세션 시크릿 (반드시 랜덤 긴 문자열로 교체)
SESSION_SECRET=CHANGE_ME_TO_RANDOM_64_CHARS

# ─── 도메인 (CORS + 쿠키 도메인 설정용) ──────────────────────
# 메인 도메인
APP_URL=https://dorunhub.com
# 펀딩 서브도메인
FUNDING_URL=https://funding.dorunhub.com
# CORS 허용 오리진 (쉼표 구분)
CORS_ORIGINS=https://dorunhub.com,https://funding.dorunhub.com

# ─── Google OAuth2 ────────────────────────────────────────────
GOOGLE_CLIENT_ID=909416358091-...
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=https://dorunhub.com/api/auth/google/callback

# ─── SMTP (이메일) ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ─── 선택 ─────────────────────────────────────────────────────
# JWT_SECRET=CHANGE_ME
# OPENAI_API_KEY=sk-...
